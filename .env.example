# Supabase (optional). When set, the admin login uses Supabase Auth and the
# visitor analytics + content edits are shared across all visitors. When unset,
# the app falls back to localStorage (per-browser, login dcgnrg/dcgnrg).
#
# Copy this file to .env and fill in your project's values
# (Supabase dashboard → Project Settings → API).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
